# Copy to ~/.claude-sessions/.env

# Bot token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC...

# Your chat ID(s). Comma-separated allow-list. Send /whoami to the bot after
# starting it (or message @userinfobot) to get your chat id.
TELEGRAM_CHAT_ID=123456789

# Optional overrides:
# CLAUDE_BIN=claude
# URL_TIMEOUT_MS=45000
# READY_TIMEOUT_MS=15000
